# Vite build-time only (copy to .env). All optional — app works without these.
# Runtime Worker secrets (INTERNAL_API_KEY, API_UPSTREAM_URL) go in .dev.vars — see docs/ENV.md

# OGP / canonical (client bundle). Remote server-side sitemap uses wrangler PUBLIC_ENV__SITE_URL.
PUBLIC_ENV__SITE_URL=https://your-domain.example.com

# Footer repo link (defaults to upstream)
PUBLIC_ENV__GITHUB_REPO=https://github.com/your-org/your-fork

# Analytics / error reporting (omit to disable)
PUBLIC_ENV__GOOGLE_ANALYTICS=G-XXXXXXXXXX
PUBLIC_ENV__SENTRY_DSN=

# Contact form embed URL (defaults to official form)
PUBLIC_ENV__CONTACT_FORM_URL=

# Screener data loading: all (default) | server
# VITE_SCREENER_MODE=all
