{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@edinet/db": ["../../packages/db/src/index.ts"],
      "@edinet/db/*": ["../../packages/db/src/*"],
      "@edinet/types": ["../../packages/types/src/index.ts"],
      "@edinet/metrics": ["../../packages/metrics/src/index.ts"],
      "@edinet/metrics/*": ["../../packages/metrics/src/*"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
