{
  "name": "@edinet/db",
  "version": "2.0.0-alpha.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./queries": "./src/queries.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
